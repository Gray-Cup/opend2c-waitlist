# Database (server-side only — never expose this)
# Format: postgresql://user:password@host:5432/dbname
# For Cloudflare Workers deployment, use a connection pooler (e.g. Neon serverless, pgBouncer)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudflare Turnstile
# Get from: https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Discord Webhook (server-side only — never expose this)
# Create in Discord: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
